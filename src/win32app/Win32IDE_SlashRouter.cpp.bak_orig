SlashCommandResult HandleSearch(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (!ide) return {false, "", "No IDE context"};
    if (args.empty()) return {false, "", "Usage: /search <query>"};
    
    std::string query;
    for (const auto& arg : args) { query += arg + " "; }
    
    // Search in current directory
    std::string currentDir = std::filesystem::current_path().string();
    std::vector<std::string> files = ListFilesInDirectory(currentDir, ".cpp");
    
    std::string results = "Search results for: " + query + "\n\n";
    int found = 0;
    
    for (const auto& file : files)
    {
        std::string content = ReadFileContent(file);
        if (content.find(query) != std::string::npos)
        {
            results += "  " + file + "\n";
            found++;
            if (found >= 20) break;
        }
    }
    
    if (found == 0)
    {
        results += "No matches found.\n";
    }
    else
    {
        results += "\nFound " + std::to_string(found) + " file(s).\n";
    }
    
    ide->appendToOutput("[Slash] /search: " + query + "\n", "Output", Win32IDE::OutputSeverity::Info);
    
    return {true, results, ""};
}

SlashCommandResult HandleClear(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (ide)
    {
        ide->clearOutput("Output");
        ide->clearOutput("General");
    }
    return {true, "Output cleared", ""};
}

SlashCommandResult HandleModel(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (!ide) return {false, "", "No IDE context"};
    
    if (args.empty())
    {
        // List available models
        auto models = ide->getAvailableModels();
        std::string result = "Available models:\n";
        for (const auto& m : models)
        {
            result += "  " + m + "\n";
        }
        result += "\nLoaded: " + (ide->getLoadedModelPath().empty() ? "<none>" : ide->getLoadedModelPath());
        return {true, result, ""};
    }
    
    // Set model
    std::string modelPath = args[0];
    for (size_t i = 1; i < args.size(); ++i)
    {
        modelPath += " " + args[i];
    }
    
    ide->appendToOutput("[Slash] /model loading: " + modelPath + "\n", "Output", Win32IDE::OutputSeverity::Info);
    
    // Trigger model load
    bool loaded = ide->loadModelFromPath(modelPath);
    
    if (loaded)
    {
        return {true, "Model loaded: " + modelPath, ""};
    }
    else
    {
        return {false, "", "Failed to load model: " + modelPath};
    }
}

SlashCommandResult HandleStatus(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (!ide) return {false, "", "No IDE context"};
    
    std::string status = "=== RawrXD Status ===\n\n";
    status += "Ollama: " + std::string(ide->isOllamaConnected() ? "Connected" : "Disconnected") + "\n";
    status += "Models discovered: " + std::to_string(ide->getAvailableModels().size()) + "\n";
    status += "Loaded model: " + (ide->getLoadedModelPath().empty() ? "<none>" : ide->getLoadedModelPath()) + "\n";
    status += "Current file: " + (ide->getCurrentFile().empty() ? "<none>" : ide->getCurrentFile()) + "\n";
    status += "KV-Cache seq_len: " + std::to_string(ide->getKVCacheSeqLen()) + "\n";
    
    return {true, status, ""};
}

SlashCommandResult HandleConfig(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (!ide) return {false, "", "No IDE context"};
    
    if (args.empty())
    {
        return {false, "", "Usage: /config <key> [value]\nKeys: temperature, max_tokens, context_window"};
    }
    
    std::string key = args[0];
    
    if (args.size() == 1)
    {
        // Get config
        return {true, "Config " + key + " = (current value)", ""};
    }
    
    // Set config
    std::string value = args[1];
    
    ide->appendToOutput("[Slash] /config " + key + " = " + value + "\n", "Output", Win32IDE::OutputSeverity::Info);
    
    return {true, "Config updated: " + key + " = " + value, ""};
}

}  // namespace

// ============================================================================
// SlashRouter Class
// ============================================================================

class SlashRouter
{
public:
    SlashRouter()
    {
        // Register all 25 commands
        m_handlers["add"] = HandleAdd;
        m_handlers["sub"] = HandleSub;
        m_handlers["mul"] = HandleMul;
        m_handlers["div"] = HandleDiv;
        m_handlers["pow"] = HandlePow;
        m_handlers["mod"] = HandleMod;
        m_handlers["concat"] = HandleConcat;
        m_handlers["upper"] = HandleUpper;
        m_handlers["lower"] = HandleLower;
        m_handlers["len"] = HandleLen;
        m_handlers["echo"] = HandleEcho;
        m_handlers["time"] = HandleTime;
        m_handlers["help"] = HandleHelp;
        m_handlers["fix"] = HandleFix;
        m_handlers["gen"] = HandleGen;
        m_handlers["explain"] = HandleExplain;
        m_handlers["refactor"] = HandleRefactor;
        m_handlers["test"] = HandleTest;
        m_handlers["doc"] = HandleDoc;
        m_handlers["search"] = HandleSearch;
        m_handlers["clear"] = HandleClear;
        m_handlers["model"] = HandleModel;
        m_handlers["status"] = HandleStatus;
        m_handlers["config"] = HandleConfig;
    }

    SlashCommandResult Route(const std::string& input, Win32IDE* ide)
    {
        // 1. Validate parity if present
        if (input.find('|') != std::string::npos)
        {
            if (!ValidateParity(input))
            {
                return {false, "", "Parity check failed"};
            }
        }

        // 2. Remove parity part if present
        std::string cmdPart = input;
        size_t pipePos = input.find('|');
        if (pipePos != std::string::npos)
        {
            cmdPart = input.substr(0, pipePos);
        }

        // 3. Parse command and arguments
        std::istringstream iss(cmdPart);
        std::string cmd;
        iss >> cmd;

        if (cmd.empty() || cmd[0] != '/')
        {
            return {false, "", "Invalid command format"};
        }

        cmd = cmd.substr(1);  // Remove leading '/'

        std::vector<std::string> args;
        std::string arg;
        while (iss >> arg)
        {
            args.push_back(arg);
        }

        // 4. Route to handler
        auto it = m_handlers.find(cmd);
        if (it == m_handlers.end())
        {
            return {false, "", "Unknown command: /" + cmd + "\nType /help for available commands"};
        }

        return it->second(args, ide);
    }

    std::string MakeParityItem(const std::string& cmdLine)
    {
        uint8_t parity = ComputeParityBit(cmdLine);
        return cmdLine + "|" + std::to_string(parity);
    }

private:
    std::map<std::string, SlashCommandHandler> m_handlers;
};

// Global router instance
static SlashRouter g_slashRouter;

// ============================================================================
// Public API
// ============================================================================

extern "C"
{

bool SlashRouter_Validate(const char* input)
{
    if (!input) return false;
    return ValidateParity(std::string(input));
}

const char* SlashRouter_Route(const char* input, void* ide)
{
    static std::string s_result;
    if (!input) return "Error: null input";
    
    SlashCommandResult result = g_slashRouter.Route(std::string(input), static_cast<Win32IDE*>(ide));
    
    if (result.success)
    {
        s_result = "OK: " + result.output;
    }
    else
    {
        s_result = "Error: " + result.error;
    }
    
    return s_result.c_str();
}

const char* SlashRouter_MakeParityItem(const char* cmdLine)
{
    static std::string s_parityItem;
    if (!cmdLine) return "";
    s_parityItem = g_slashRouter.MakeParityItem(std::string(cmdLine));
    return s_parityItem.c_str();
}

}  // extern "C"