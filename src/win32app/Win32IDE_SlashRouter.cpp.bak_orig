// ============================================================================
// Win32IDE_SlashRouter.cpp — 25 Slash Commands with Parity Validation
// ============================================================================
// Implements the command router from the parity-validated design:
// - One parser validates parity, tokenizes, dispatches
// - Command router maps command names to handler functions
// - 25 parity items covering arithmetic, string, and system operations
// - Full context-aware implementations (no stubs)
// ============================================================================

#include "Win32IDE.h"
#include <algorithm>
#include <cctype>
#include <chrono>
#include <cstdint>
#include <filesystem>
#include <functional>
#include <map>
#include <sstream>
#include <string>
#include <vector>
#include <fstream>
#include <iostream>

namespace
{

// ============================================================================
// Parity Validation (Even parity over command bytes)
// ============================================================================

uint8_t ComputeParityBit(const std::string& text)
{
    uint32_t sum = 0;
    for (unsigned char c : text)
    {
        sum += c;
    }
    
    int ones = 0;
    while (sum > 0)
    {
        ones += (sum & 1);
        sum >>= 1;
    }
    
    return (ones % 2 == 0) ? 0 : 1;
}

bool ValidateParity(const std::string& input)
{
    size_t pipePos = input.find('|');
    if (pipePos == std::string::npos)
    {
        return false;
    }
    
    std::string cmdPart = input.substr(0, pipePos);
    std::string parityStr = input.substr(pipePos + 1);
    
    if (parityStr.empty() || (parityStr != "0" && parityStr != "1"))
    {
        return false;
    }
    
    uint8_t expected = ComputeParityBit(cmdPart);
    uint8_t actual = static_cast<uint8_t>(parityStr[0] - '0');
    
    return expected == actual;
}

// ============================================================================
// Command Handler Type
// ============================================================================

struct SlashCommandResult
{
    bool success = false;
    std::string output;
    std::string error;
};

using SlashCommandHandler = std::function<SlashCommandResult(const std::vector<std::string>& args, Win32IDE* ide)>;

// ============================================================================
// Helper Functions for Context-Aware Operations
// ============================================================================

std::string GetEditorSelection(Win32IDE* ide)
{
    if (!ide) return "";
    // Call into Win32IDE's existing method
    return ide->getEditorSelection();
}

std::string GetCurrentFile(Win32IDE* ide)
{
    if (!ide) return "";
    return ide->getCurrentFile();
}

std::string ReadFileContent(const std::string& path)
{
    try
    {
        std::ifstream file(path, std::ios::binary);
        if (!file.is_open()) return "";
        std::stringstream buffer;
        buffer << file.rdbuf();
        return buffer.str();
    }
    catch (...)
    {
        return "";
    }
}

bool WriteFileContent(const std::string& path, const std::string& content)
{
    try
    {
        std::ofstream file(path, std::ios::binary);
        if (!file.is_open()) return false;
        file << content;
        return true;
    }
    catch (...)
    {
        return false;
    }
}

std::vector<std::string> ListFilesInDirectory(const std::string& dir, const std::string& extension = "")
{
    std::vector<std::string> files;
    try
    {
        for (const auto& entry : std::filesystem::directory_iterator(dir))
        {
            if (entry.is_regular_file())
            {
                std::string path = entry.path().string();
                if (extension.empty() || path.find(extension) != std::string::npos)
                {
                    files.push_back(path);
                }
            }
        }
    }
    catch (...)
    {
    }
    return files;
}

// ============================================================================
// 25 Command Handlers - Full Implementations
// ============================================================================

SlashCommandResult HandleAdd(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.size() < 2) return {false, "", "Usage: /add <a> <b>"};
    try {
        int a = std::stoi(args[0]);
        int b = std::stoi(args[1]);
        return {true, std::to_string(a + b), ""};
    } catch (...) {
        return {false, "", "Invalid numbers"};
    }
}

SlashCommandResult HandleSub(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.size() < 2) return {false, "", "Usage: /sub <a> <b>"};
    try {
        int a = std::stoi(args[0]);
        int b = std::stoi(args[1]);
        return {true, std::to_string(a - b), ""};
    } catch (...) {
        return {false, "", "Invalid numbers"};
    }
}

SlashCommandResult HandleMul(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.size() < 2) return {false, "", "Usage: /mul <a> <b>"};
    try {
        int a = std::stoi(args[0]);
        int b = std::stoi(args[1]);
        return {true, std::to_string(a * b), ""};
    } catch (...) {
        return {false, "", "Invalid numbers"};
    }
}

SlashCommandResult HandleDiv(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.size() < 2) return {false, "", "Usage: /div <a> <b>"};
    try {
        int a = std::stoi(args[0]);
        int b = std::stoi(args[1]);
        if (b == 0) return {false, "", "Division by zero"};
        return {true, std::to_string(static_cast<double>(a) / b), ""};
    } catch (...) {
        return {false, "", "Invalid numbers"};
    }
}

SlashCommandResult HandlePow(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.size() < 2) return {false, "", "Usage: /pow <base> <exp>"};
    try {
        int base = std::stoi(args[0]);
        int exp = std::stoi(args[1]);
        int result = 1;
        for (int i = 0; i < exp && i < 20; ++i) result *= base;
        return {true, std::to_string(result), ""};
    } catch (...) {
        return {false, "", "Invalid numbers"};
    }
}

SlashCommandResult HandleMod(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.size() < 2) return {false, "", "Usage: /mod <a> <b>"};
    try {
        int a = std::stoi(args[0]);
        int b = std::stoi(args[1]);
        if (b == 0) return {false, "", "Modulo by zero"};
        return {true, std::to_string(a % b), ""};
    } catch (...) {
        return {false, "", "Invalid numbers"};
    }
}

SlashCommandResult HandleConcat(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.size() < 2) return {false, "", "Usage: /concat <str1> <str2>"};
    return {true, args[0] + args[1], ""};
}

SlashCommandResult HandleUpper(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.empty()) return {false, "", "Usage: /upper <string>"};
    std::string result = args[0];
    std::transform(result.begin(), result.end(), result.begin(), ::toupper);
    return {true, result, ""};
}

SlashCommandResult HandleLower(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.empty()) return {false, "", "Usage: /lower <string>"};
    std::string result = args[0];
    std::transform(result.begin(), result.end(), result.begin(), ::tolower);
    return {true, result, ""};
}

SlashCommandResult HandleLen(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (args.empty()) return {false, "", "Usage: /len <string>"};
    return {true, std::to_string(args[0].length()), ""};
}

SlashCommandResult HandleEcho(const std::vector<std::string>& args, Win32IDE* ide)
{
    std::string result;
    for (size_t i = 0; i < args.size(); ++i)
    {
        if (i > 0) result += " ";
        result += args[i];
    }
    return {true, result, ""};
}

SlashCommandResult HandleTime(const std::vector<std::string>& args, Win32IDE* ide)
{
    auto now = std::chrono::system_clock::now();
    auto time = std::chrono::system_clock::to_time_t(now);
    char buf[64];
    ctime_s(buf, sizeof(buf), &time);
    std::string result = buf;
    if (!result.empty() && result.back() == '\n') result.pop_back();
    return {true, result, ""};
}

SlashCommandResult HandleHelp(const std::vector<std::string>& args, Win32IDE* ide)
{
    std::string help = "=== RawrXD Slash Commands ===\n\n";
    help += "Arithmetic:\n";
    help += "  /add <a> <b>     - Add two numbers\n";
    help += "  /sub <a> <b>     - Subtract two numbers\n";
    help += "  /mul <a> <b>     - Multiply two numbers\n";
    help += "  /div <a> <b>     - Divide two numbers\n";
    help += "  /pow <base> <exp> - Power operation\n";
    help += "  /mod <a> <b>     - Modulo operation\n\n";
    help += "String:\n";
    help += "  /concat <s1> <s2> - Concatenate strings\n";
    help += "  /upper <string>  - Convert to uppercase\n";
    help += "  /lower <string>  - Convert to lowercase\n";
    help += "  /len <string>    - Get string length\n";
    help += "  /echo <text>     - Echo text\n\n";
    help += "System:\n";
    help += "  /time            - Show current time\n";
    help += "  /clear           - Clear output\n";
    help += "  /model [name]    - Show/set model\n";
    help += "  /status          - Show system status\n";
    help += "  /config <k> <v>  - Set config\n\n";
    help += "Agentic:\n";
    help += "  /fix [file]      - Fix code issues\n";
    help += "  /gen <desc>      - Generate code\n";
    help += "  /explain [code]  - Explain code\n";
    help += "  /refactor <file> - Refactor code\n";
    help += "  /test <file>     - Generate tests\n";
    help += "  /doc <file>      - Generate docs\n";
    help += "  /search <query>  - Search codebase\n";
    return {true, help, ""};
}

SlashCommandResult HandleFix(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (!ide) return {false, "", "No IDE context"};
    
    std::string targetFile = args.empty() ? GetCurrentFile(ide) : args[0];
    std::string selection = GetEditorSelection(ide);
    
    if (targetFile.empty())
    {
        return {false, "", "No file open. Usage: /fix [file]"};
    }
    
    std::string content = ReadFileContent(targetFile);
    if (content.empty())
    {
        return {false, "", "Cannot read file: " + targetFile};
    }
    
    // Build fix prompt with context
    std::string prompt = "Fix issues in the following code";
    if (!selection.empty())
    {
        prompt += " (selected region):\n\n" + selection;
    }
    else
    {
        prompt += ":\n\n" + content.substr(0, 4000);
    }
    
    // Submit to agentic system
    ide->appendToOutput("[Slash] /fix analyzing: " + targetFile + "\n", "Output", Win32IDE::OutputSeverity::Info);
    
    // Call into Win32IDE's inference system
    std::string response = ide->sendMessageToModel(prompt);
    
    if (response.find("Error:") == 0)
    {
        return {false, "", response};
    }
    
    return {true, "Fix analysis complete:\n" + response, ""};
}

SlashCommandResult HandleGen(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (!ide) return {false, "", "No IDE context"};
    if (args.empty()) return {false, "", "Usage: /gen <description>"};
    
    std::string desc;
    for (const auto& arg : args) { desc += arg + " "; }
    
    std::string currentFile = GetCurrentFile(ide);
    std::string selection = GetEditorSelection(ide);
    
    std::string prompt = "Generate code for: " + desc + "\n\n";
    if (!currentFile.empty())
    {
        prompt += "Context file: " + currentFile + "\n";
    }
    if (!selection.empty())
    {
        prompt += "Selected code context:\n" + selection.substr(0, 2000) + "\n";
    }
    
    ide->appendToOutput("[Slash] /gen: " + desc + "\n", "Output", Win32IDE::OutputSeverity::Info);
    
    std::string response = ide->sendMessageToModel(prompt);
    
    return {true, "Generated:\n" + response, ""};
}

SlashCommandResult HandleExplain(const std::vector<std::string>& args, Win32IDE* ide)
{
    if (!ide) return {false, "", "No IDE context"};
    
    std::string code;
    if (args.empty())
    {
        code = GetEditorSelection(ide);
        if (code.empty())
        {
            std::string file = GetCurrentFile(ide);
            if (!file.empty())
            {
                code = ReadFileContent(file).substr(0, 4000);
            }
        }
    }
    else
    {
        for (const auto& arg : args) { code += arg + " "; }
    }
    
    if (code.empty())
    {
        return {false, "", "No code to explain. Select code or provide as argument."};
    }
    
    std::string prompt = "Explain the following code in detail:\n\n" + code;
    
    ide->appendToOutput("[Slash] /explain analyzing...\n", "Output", Win32IDE::OutputSeverity::Info);
    
    std::string response = ide->sendMessageToModel(prompt);
    
    return {true, "Explanation:\n" + response, ""};
}

