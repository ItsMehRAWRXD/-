<?xml version="1.0" encoding="utf-8"?>
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable"
              xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <Extern href="stdidcmd.h"/>
  <Extern href="vsshlids.h"/>
  <Extern href="msobtnid.h"/>

  <Commands package="guidRawrXDPrometheusNativePkg">

    <Menus>
      <Menu guid="guidRawrXDPrometheusNativeCmdSet" id="IDM_RawrXD_Prometheus_Menu" priority="0x0100" type="Menu">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_TOOLS"/>
        <Strings>
          <ButtonText>&amp;RawrXD Prometheus</ButtonText>
          <CommandName>RawrXD Prometheus</CommandName>
        </Strings>
      </Menu>
    </Menus>

    <Groups>
      <Group guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Main" priority="0x0100">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDM_RawrXD_Prometheus_Menu"/>
      </Group>
      <Group guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Models" priority="0x0200">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDM_RawrXD_Prometheus_Menu"/>
      </Group>
      <Group guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Inference" priority="0x0300">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDM_RawrXD_Prometheus_Menu"/>
      </Group>
    </Groups>

    <Buttons>
      <Button guid="guidRawrXDPrometheusNativeCmdSet" id="cmdidPrometheusOutputWindow" priority="0x0100" type="Button">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Main"/>
        <Icon guid="guidImages" id="bmpPic1"/>
        <Strings>
          <ButtonText>&amp;Output Window</ButtonText>
          <ToolTipText>Show Prometheus Output Window</ToolTipText>
          <CommandName>PrometheusOutputWindow</CommandName>
        </Strings>
      </Button>

      <Button guid="guidRawrXDPrometheusNativeCmdSet" id="cmdidPrometheusModelBrowser" priority="0x0101" type="Button">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Main"/>
        <Icon guid="guidImages" id="bmpPic2"/>
        <Strings>
          <ButtonText>&amp;Model Browser</ButtonText>
          <ToolTipText>Browse and manage AI models</ToolTipText>
          <CommandName>PrometheusModelBrowser</CommandName>
        </Strings>
      </Button>

      <Button guid="guidRawrXDPrometheusNativeCmdSet" id="cmdidPrometheusLoadModel" priority="0x0200" type="Button">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Models"/>
        <Icon guid="guidImages" id="bmpPic3"/>
        <Strings>
          <ButtonText>&amp;Load Model...</ButtonText>
          <ToolTipText>Load a GGUF model into Prometheus engine</ToolTipText>
          <CommandName>PrometheusLoadModel</CommandName>
        </Strings>
      </Button>

      <Button guid="guidRawrXDPrometheusNativeCmdSet" id="cmdidPrometheusUnloadModel" priority="0x0201" type="Button">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Models"/>
        <Icon guid="guidImages" id="bmpPic4"/>
        <Strings>
          <ButtonText>&amp;Unload Model</ButtonText>
          <ToolTipText>Unload the currently loaded model</ToolTipText>
          <CommandName>PrometheusUnloadModel</CommandName>
        </Strings>
      </Button>

      <Button guid="guidRawrXDPrometheusNativeCmdSet" id="cmdidPrometheusStartInference" priority="0x0300" type="Button">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Inference"/>
        <Icon guid="guidImages" id="bmpPic5"/>
        <Strings>
          <ButtonText>&amp;Start Inference</ButtonText>
          <ToolTipText>Start AI inference on selected text or file</ToolTipText>
          <CommandName>PrometheusStartInference</CommandName>
        </Strings>
      </Button>

      <Button guid="guidRawrXDPrometheusNativeCmdSet" id="cmdidPrometheusStopInference" priority="0x0301" type="Button">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Inference"/>
        <Icon guid="guidImages" id="bmpPic6"/>
        <Strings>
          <ButtonText>S&amp;top Inference</ButtonText>
          <ToolTipText>Stop current inference</ToolTipText>
          <CommandName>PrometheusStopInference</CommandName>
        </Strings>
      </Button>

      <Button guid="guidRawrXDPrometheusNativeCmdSet" id="cmdidPrometheusSettings" priority="0x0400" type="Button">
        <Parent guid="guidRawrXDPrometheusNativeCmdSet" id="IDG_RawrXD_Prometheus_Main"/>
        <Icon guid="guidImages" id="bmpPic7"/>
        <Strings>
          <ButtonText>&amp;Settings...</ButtonText>
          <ToolTipText>Configure Prometheus engine settings</ToolTipText>
          <CommandName>PrometheusSettings</CommandName>
        </Strings>
      </Button>
    </Buttons>

    <Bitmaps>
      <Bitmap guid="guidImages" href="Resources\Images.png" usedList="bmpPic1, bmpPic2, bmpPic3, bmpPic4, bmpPic5, bmpPic6, bmpPic7"/>
    </Bitmaps>

  </Commands>

  <Symbols>
