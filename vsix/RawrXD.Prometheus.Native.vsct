    <IDSymbol name="IDG_RawrXD_Prometheus_Models" value="0x1200" />
    <IDSymbol name="IDG_RawrXD_Prometheus_Inference" value="0x1300" />

    <IDSymbol name="cmdidPrometheusOutputWindow" value="0x0100" />
