{
    "name": "rawrxd-vscode",
    "displayName": "RawrXD",
    "description": "Native x64 MASM-Powered AI IDE Bridge",
    "version": "0.1.0",
    "publisher": "ItsMehRAWRXD",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "AI"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "rawrxd.sendContext",
                "title": "RawrXD: Sync Context to MASM Bridge"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^16.11.7",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.1.3"
    },
    "dependencies": {
        "ffi-napi": "^4.0.3",
        "ref-napi": "^3.0.3"
    }
}
