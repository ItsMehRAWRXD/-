    Qt6Gui.dll
    Qt6Widgets.dll
    Qt5Network.dll
    Qt6Network.dll
    libqt5core.dll
    libqt6core.dll
    Qt5Core.dll
    Qt5Gui.dll
    Qt5Widgets.dll
