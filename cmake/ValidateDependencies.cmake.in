# =============================================================================
# cmake/ValidateDependencies.cmake.in - Validate No Electron Dependencies
# =============================================================================
# This script is configured by CMake and invoked as a -P script after build
# to validate that no forbidden Electron/Node.js/Qt DLLs are linked.
#
# Usage:
#   cmake -DDEPS_FILE=<path> -DTARGET=<name> -P ValidateDependencies.cmake
# =============================================================================

# List of FORBIDDEN dependencies (Electron, Node.js, Qt, etc.)
set(FORBIDDEN_DLLS
    node.dll
    node.exe
    electron.dll
    electron.exe
    nodejs.dll
