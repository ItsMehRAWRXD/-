function(validate_dll DLL_PATH)
    get_filename_component(DLL_NAME "${DLL_PATH}" NAME)
    string(TOLOWER "${DLL_NAME}" DLL_NAME_LOWER)
    
    # Check if forbidden
    foreach(FORBIDDEN ${FORBIDDEN_DLLS})
        string(TOLOWER "${FORBIDDEN}" FORBIDDEN_LOWER)
        if(DLL_NAME_LOWER STREQUAL FORBIDDEN_LOWER)
            message(FATAL_ERROR 
                "FORBIDDEN DEPENDENCY DETECTED: ${DLL_NAME}\n"
                "This indicates Electron/Node.js/Qt contamination!\n"
                "RawrXD requires pure native C++ - no Electron allowed.\n"
                "Please remove any references to ${FORBIDDEN} from your build."
            )
        endif()
    endforeach()
    
    # Check if unknown
    set(IS_ALLOWED FALSE)
    foreach(ALLOWED ${ALLOWED_DLLS})
        string(TOLOWER "${ALLOWED}" ALLOWED_LOWER)
        if(DLL_NAME_LOWER STREQUAL ALLOWED_LOWER)
            set(IS_ALLOWED TRUE)
            break()
        endif()
    endforeach()
    
    if(NOT IS_ALLOWED)
        message(WARNING 
            "UNKNOWN DEPENDENCY: ${DLL_NAME}\n"
            "This DLL is not in the allowed list.\n"
            "If this is a legitimate dependency, add it to ALLOWED_DLLS in cmake/ValidateDependencies.cmake.in"
        )
    endif()
endfunction()

function(validate_binary_dependencies TARGET_NAME)
    get_target_property(BINARY_FILE "${TARGET_NAME}" BINARY_OUTPUT_LOCATION)
    if(NOT BINARY_FILE)
        get_target_property(BINARY_FILE "${TARGET_NAME}" RUNTIME_OUTPUT_DIRECTORY)
        set(BINARY_FILE "${BINARY_FILE}/${CMAKE_BUILD_TYPE}/${TARGET_NAME}.exe")
    endif()
    
    if(NOT EXISTS "${BINARY_FILE}")
        message(STATUS "Binary not found: ${BINARY_FILE}")
        return()
    endif()
    
    message(STATUS "Validating dependencies for: ${TARGET_NAME}")
    
    # Run dumpbin to get imports
    execute_process(
        COMMAND "@DUMPBIN_EXE@" /DEPENDENTS "${BINARY_FILE}"
        OUTPUT_VARIABLE DUMPBIN_OUTPUT
        ERROR_VARIABLE DUMPBIN_ERROR
        RESULT_VARIABLE DUMPBIN_RESULT
        OUTPUT_STRIP_TRAILING_WHITESPACE
    )
    
    if(NOT DUMPBIN_RESULT EQUAL 0)
        message(WARNING "dumpbin failed for ${TARGET_NAME}: ${DUMPBIN_ERROR}")
        return()
    endif()
    
    # Parse imports
    string(REGEX MATCHALL "^[ \t]+[^ \t\r\n]+\\.dll" DLL_MATCHES "${DUMPBIN_OUTPUT}")
    
    foreach(DLL_MATCH ${DLL_MATCHES})
        string(STRIP "${DLL_MATCH}" DLL_NAME)
        validate_dll("${DLL_NAME}")
    endforeach()
    
    message(STATUS "  Dependencies validated for ${TARGET_NAME}")
endfunction()

# Main validation
if(DEFINED DEPS_FILE AND EXISTS "${DEPS_FILE}")
    file(STRINGS "${DEPS_FILE}" DEPENDENCY_LINES)
    foreach(LINE ${DEPENDENCY_LINES})
        string(STRIP "${LINE}" LINE)
        if(LINE MATCHES "\\.dll$")
            validate_dll("${LINE}")
        endif()
    endforeach()
endif()
